# =============================================================================
# Supabase (required)
# Get these from your Supabase project: Project Settings > API
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# =============================================================================
# Paddle — payments (required only if payments are enabled)
# Hosted Checkout URLs for each plan (Sandbox or Production)
# =============================================================================
NEXT_PUBLIC_PADDLE_HSC_1M=https://sandbox-pay.paddle.io/hsc_...
NEXT_PUBLIC_PADDLE_HSC_2M=https://sandbox-pay.paddle.io/hsc_...
NEXT_PUBLIC_PADDLE_HSC_3M=https://sandbox-pay.paddle.io/hsc_...

# Secret used to verify Paddle webhook signatures (Developer Tools > Webhooks)
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret_here

# Paddle REST API key, used server-side to look up/cancel subscriptions
PADDLE_API_KEY=your_paddle_api_key_here

# "sandbox" or "production" — controls which Paddle API host is used
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox

# =============================================================================
# Payment feature flag (optional)
# Lets you ship the app with payments fully disabled (e.g. a pure demo
# deployment) without removing any pricing UI.
# =============================================================================
NEXT_PUBLIC_PAYMENT_ENABLED=true
PAYMENT_ENABLED=true
NEXT_PUBLIC_PAYMENT_PROVIDER=paddle
PAYMENT_PROVIDER=paddle

# =============================================================================
# Billing / plan configuration (optional — sensible defaults are built in)
# =============================================================================
NEXT_PUBLIC_FREE_TEST_LIMIT_PER_CATEGORY=3
NEXT_PUBLIC_PAID_TEST_LIMIT_PER_CATEGORY=9999
NEXT_PUBLIC_BILLING_CYCLE_DAYS=30
NEXT_PUBLIC_PAYMENT_BEST_VALUE_PLAN=PLAN_C

# =============================================================================
# App URLs (optional — used for building absolute links, e.g. in emails)
# =============================================================================
FRONTEND_BASE_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# =============================================================================
# Instructions
# 1. Copy this file to .env.local (this exact filename, in the web/ folder)
# 2. Replace the placeholder values with your actual credentials
# 3. Never commit .env.local to version control
# =============================================================================
